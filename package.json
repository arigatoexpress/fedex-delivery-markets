{
  "name": "fedex-delivery-markets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Paper-only FedEx delivery-time prediction market demo with Robinhood Chain and Hedera oracle architecture.",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5178",
    "start": "node dist-server/index.js",
    "contracts:build": "tsx scripts/build-contract-artifacts.ts",
    "deploy:robinhood:testnet": "tsx scripts/deploy-robinhood-chain.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc --noEmit && vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist-server/index.js --external:@polymarket/clob-client-v2 --external:@cowprotocol/cow-sdk --external:@hashgraph/sdk",
    "browser:smoke": "node scripts/browser-smoke.mjs",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@cowprotocol/cow-sdk": "^9.1.0",
    "@hashgraph/sdk": "^2.80.0",
    "@hono/node-server": "^1.14.1",
    "@polymarket/clob-client-v2": "^1.0.6",
    "hono": "^4.7.10",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.4",
    "viem": "^2.49.3",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "playwright": "^1.60.0",
    "solc": "^0.8.35",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3"
  },
  "overrides": {
    "bn.js": "^5.2.3",
    "protobufjs": "^8.3.0"
  }
}
