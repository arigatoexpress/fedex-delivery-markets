# Local pilot settings. Do not commit real secrets.

# Optional. If set, /api/admin/* and /api/oracle/events require:
# Authorization: Bearer <DELIVERY_MARKETS_ADMIN_TOKEN>
DELIVERY_MARKETS_ADMIN_TOKEN=

# Optional. If set, oracle events must be signed with this EVM address.
ORACLE_SIGNER_ADDRESS=

# Optional. Defaults to ./data
DELIVERY_MARKETS_DATA_DIR=

# Read-only wallet readiness. These are public addresses only.
DELIVERY_MARKETS_TESTNET_WALLET_ADDRESS=
WALLET_READINESS_TIMEOUT_MS=5000

# Optional Solana reference rail. Not required for the current EVM receipt path.
SOLANA_TESTNET_WALLET_ADDRESS=
SOLANA_RPC_URL=https://api.devnet.solana.com

# Testnet-only deploy placeholders. The deploy script still requires DEPLOY_CONTRACTS=true.
ROBINHOOD_CHAIN_RPC_URL=
DEPLOYER_PRIVATE_KEY=
DEPLOY_CONTRACTS=false
DEPLOY_PRIVATE_MARKET_CONTRACT=false
PRIVATE_MARKET_CONTRACT_ADDRESS=
